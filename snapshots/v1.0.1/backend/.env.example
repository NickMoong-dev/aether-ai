# Aether Backend — 환경 변수 예시
# 이 파일을 .env로 복사하여 사용하세요.

# ── Ollama (로컬 GPU) ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=30
OLLAMA_MAX_RETRIES=2

# ── OpenAI ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# 아래 값을 변경하면 OpenAI 호환 엔드포인트를 사용할 수 있습니다.
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic Claude ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 클라우드 GPU (OpenAI 호환 엔드포인트) ────────────────────────────
# RunPod: https://api.runpod.ai/v2/{endpoint_id}/openai
# Together.ai: https://api.together.xyz/v1
# Groq: https://api.groq.com/openai/v1
# Modal: https://{workspace}--{app}.modal.run/v1
# 자체 vLLM: http://your-gpu-server:8000/v1
CLOUD_GPU_API_KEY=
CLOUD_GPU_BASE_URL=
CLOUD_GPU_MODEL=
CLOUD_GPU_TIMEOUT=120

# ── AI 오케스트레이터 ────────────────────────────────────────────────
# 기본 프로바이더: ollama | openai | anthropic | cloud_gpu | auto
DEFAULT_PROVIDER=ollama
# 지정 프로바이더 실패 시 자동 폴백 여부
AUTO_FALLBACK=true

# ── FastAPI 서버 ─────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ── 로그 레벨 (DEBUG | INFO | WARNING | ERROR) ───────────────────────
LOG_LEVEL=INFO
