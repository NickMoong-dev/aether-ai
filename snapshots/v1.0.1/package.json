{
  "name": "aether-ai",
  "version": "1.1.0",
  "productName": "Aether AI",
  "description": "Omni-Verse IP Creation & Expansion AI Platform",
  "main": "main.js",
  "author": "NickMoong",
  "repository": {
    "type": "git",
    "url": "https://github.com/NickMoong-dev/aether-ai.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "publish": "electron-builder --win nsis --publish always"
  },
  "build": {
    "appId": "com.aether.omni-verse",
    "productName": "Aether AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "release-notes.json",
      "build/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "NickMoong-dev",
        "repo": "aether-ai",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Aether AI",
      "artifactName": "Aether_Setup_v${version}.exe",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^26.8.1"
  }
}
